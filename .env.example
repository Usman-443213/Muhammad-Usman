# =========================================================================
# SMTP CREDENTIALS & EMAIL ROUTER CONFIGURATION
# Copy this file to '.env.local' and populate it with your actual settings
# =========================================================================

# SMTP Connection Parameters
# If using Gmail, set SMTP_HOST=smtp.gmail.com, SMTP_PORT=465
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# SMTP Authentication Details
# For Gmail, SMTP_USER is your Gmail address, and SMTP_PASS is your 16-character Google App Password
# Do NOT use your regular account password. Generate an App Password in your Google Account Security settings.
SMTP_USER=usmanbhatti4945@gmail.com
SMTP_PASS=your-google-app-password-here

# Mail Sender Configuration
# This appears as the 'From' header in client autoresponders
SMTP_FROM="Muhammad Usman <usmanbhatti4945@gmail.com>"

# Primary Receiver Configuration
# Submissions from the contact form are relayed directly here
SMTP_TO=usmanbhatti4945@gmail.com
